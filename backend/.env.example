# =====================================================
# TCC朗读网站 - 环境变量配置模板
#
# 使用方法：
#   1. 复制这个文件并重命名为 .env
#   2. 填入你自己的真实配置值
#   3. .env 文件已被 .gitignore 忽略，不会上传到GitHub（保护隐私）
# =====================================================

# ---- Google Gemini API 配置 ----
# 在 https://aistudio.google.com/app/apikey 获取你的API Key
GEMINI_API_KEY=your_gemini_api_key_here

# ---- JWT 认证配置 ----
# 用于签名JWT令牌的密钥，必须是随机的长字符串
# 生成方法：在终端运行 python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_super_secret_key_change_this_in_production

# JWT令牌的加密算法（保持HS256即可）
ALGORITHM=HS256

# JWT令牌的过期时间（分钟），默认30天
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ---- 数据库配置 ----
# SQLite数据库文件路径（相对于backend目录）
DATABASE_URL=sqlite+aiosqlite:///./tts_reader.db

# ---- 服务器配置 ----
# 前端地址，用于配置CORS跨域（开发时填localhost，部署时填真实域名）
FRONTEND_URL=http://localhost:5173
